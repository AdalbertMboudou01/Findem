# Configuration de la base de données
POSTGRES_DB=assistant_prequalification
POSTGRES_USER=assistant_user
POSTGRES_PASSWORD=assistant_password
DB_HOST=localhost
DB_PORT=55432
DB_NAME=assistant_prequalification
DB_USER=assistant_user
DB_PASSWORD=assistant_password

# Configuration Spring Boot
SPRING_PROFILES_ACTIVE=docker
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/assistant_prequalification
SPRING_DATASOURCE_USERNAME=assistant_user
SPRING_DATASOURCE_PASSWORD=assistant_password
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Configuration JWT
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRATION=86400000

# Configuration Email
APP_EMAIL_HOST=smtp.gmail.com
APP_EMAIL_PORT=587
APP_EMAIL_USERNAME=your-email@gmail.com
APP_EMAIL_PASSWORD=your-app-password
APP_EMAIL_FROM=noreply@assistant-prequalification.com

# Configuration Frontend
APP_FRONTEND_URL=http://localhost:3100

# Configuration Upload
APP_UPLOAD_DIR=./uploads
