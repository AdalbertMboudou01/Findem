# Database used by docker-compose db service
POSTGRES_DB=assistant_db
POSTGRES_USER=assistant_user
POSTGRES_PASSWORD=change_me

# Spring datasource used by the backend
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/assistant_db
SPRING_DATASOURCE_USERNAME=assistant_user
SPRING_DATASOURCE_PASSWORD=change_me
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect
SERVER_PORT=8000

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRATION=86400000

# Security feature flags
APP_FEATURES_BOOTSTRAP_TEST_ENABLED=false
APP_INVITATION_EXPOSE_TOKEN=false

# File uploads
APP_UPLOAD_DIR=/app/uploads
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=10MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=10MB

# Email notifications
APP_EMAIL_HOST=smtp.gmail.com
APP_EMAIL_PORT=587
APP_EMAIL_USERNAME=your_email@example.com
APP_EMAIL_PASSWORD=your_app_password
APP_EMAIL_FROM=your_email@example.com

# Frontend URL allowed/used by the backend
APP_FRONTEND_URL=http://localhost:3100

# Generic AI configuration for AI personas
APP_AI_ENABLED=false
APP_AI_BASE_URL=https://api.openai.com
APP_AI_API_KEY=
APP_AI_MODEL=gpt-4o-mini

# Legacy semantic extractor configuration.
# Kept for compatibility. APP_AI_* is preferred for AI personas.
APP_SEMANTIC_EXTRACTOR_ENABLED=false
APP_SEMANTIC_EXTRACTOR_BASE_URL=https://api.openai.com
APP_SEMANTIC_EXTRACTOR_API_KEY=
APP_SEMANTIC_EXTRACTOR_MODEL=gpt-4o-mini
APP_SEMANTIC_EXTRACTOR_REQUIRE_LLM=true

# Frontend build/runtime, if the frontend service is present
VITE_API_BASE_URL=http://localhost:8100
